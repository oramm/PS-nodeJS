NODE_ENV=development
TRUST_PROXY=false
ENABLE_DEV_LOGIN=true
PERSONS_MODEL_V2_LEGACY_READ=false
PERSONS_MODEL_V2_SESSIONS_ACCOUNT_ENABLED=false

# ============================================================
# Google API / OAuth - Konfiguracja
# ============================================================
REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# MongoDB - Konfiguracja
# ============================================================
MONGO_URI=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=envi
MONGO_USER=
MONGO_PASSWORD=

# ============================================================
# MySQL/MariaDB - Konfiguracja
# ============================================================
DB_CONNECTION_LIMIT=10
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=envikons_myEnvi
DB_MULTIPLE_STATEMENTS=true
TZ='Europe/Warsaw'

# ============================================================
# SMTP - Konfiguracja
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# IMAP - Konfiguracja
# ============================================================
BIURO_IMAP_HOST=
BIURO_IMAP_PORT=143
BIURO_IMAP_SECURE=false
BIURO_IMAP_USER=
BIURO_IMAP_PASSWORD=

# ============================================================
# Admin / Powiadomienia - Konfiguracja
# ============================================================
PS_ADMIN_MAIL=

# ============================================================
# API (Backend + LLM) - Konfiguracja
# ============================================================
API_PORT=3000
API_BASE_URL=http://localhost:3000
OPENAI_API_KEY=
PUBLIC_PROFILE_SUBMISSION_BASE_URL=http://localhost:9000/docs/#/public/experience-update
PUBLIC_PROFILE_SUBMISSION_LINK_TTL_DAYS=30
PUBLIC_PROFILE_SUBMISSION_VERIFY_CODE_TTL_MINUTES=10
PUBLIC_PROFILE_SUBMISSION_VERIFY_CODE_MAX_ATTEMPTS=5
PUBLIC_PROFILE_SUBMISSION_SESSION_TTL_HOURS=24
PUBLIC_PROFILE_SUBMISSION_LINK_RECOVERY_COOLDOWN_SECONDS=60

# ============================================================
# Session - Konfiguracja
# ============================================================
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000

# ============================================================
# JWT - Konfiguracja
# ============================================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# ============================================================
# Upload plików - Konfiguracja
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================================
# Logowanie - Konfiguracja
# ============================================================
LOG_LEVEL=debug
LOG_DIR=./logs

# ============================================================
# KSeF (Krajowy System e-Faktur) - Konfiguracja
# ============================================================
# Dokumentacja: https://www.gov.pl/web/kas/ksef
# API Test: https://web2te-ksef.mf.gov.pl/web/login
# ============================================================
# Allowed values: test | production
# For production runtime (e.g. Heroku): use production
KSEF_ENVIRONMENT=test
KSEF_API_BASE_URL=
KSEF_NIP=
KSEF_TOKEN=
# Optional helper for local runs with production KSeF.
# Used when KSEF_ENVIRONMENT=production (preferred over KSEF_TOKEN).
KSEF_TOKEN_PRODUCTION=
KSEF_SELLER_NAME=
KSEF_SELLER_STREET=
KSEF_SELLER_CITY=
KSEF_SELLER_POSTAL_CODE=
KSEF_SELLER_BANK_ACCOUNT=
KSEF_SELLER_BANK_NAME=

# ============================================================
# Bank Sync - Konfiguracja
# ============================================================
# Próg pewności dla automatycznego dopasowania (0.0–1.0)
BANK_MATCH_AUTO_THRESHOLD=0.85
# Próg pewności dla proponowanego dopasowania (0.0–1.0)
BANK_MATCH_PROPOSE_THRESHOLD=0.5
# Tolerancja kwotowa dla dopasowania (w groszach); używana TYLKO przez algorytm dopasowania
BANK_AMOUNT_TOLERANCE_GROSZE=1
# Okno czasowe dla dopasowania dat (w dniach)
BANK_DATE_WINDOW_DAYS=60

# ============================================================
# Bug backlog / GitHub sync - Konfiguracja
# ============================================================
BUG_GITHUB_SYNC_ENABLED=false
BUG_GITHUB_REPO=
BUG_GITHUB_TOKEN=
BUG_ERROR_MAIL_CRITICAL_ONLY=true
BUG_CLIENT_ERROR_ENABLED=false
# Allow authenticated browser session to report client errors without shared secret header.
BUG_CLIENT_ERROR_ALLOW_SESSION=true
# Required when BUG_CLIENT_ERROR_ENABLED=true
BUG_CLIENT_ERROR_SECRET=
BUG_ADMIN_READ_MODEL_ENABLED=false
BUG_ADMIN_READ_MODEL_SECRET=
BUGFIX_DAILY_INBOX_CRON_ENABLED=false
BUGFIX_DAILY_INBOX_CRON_EXPRESSION=30 6 * * *
BUGFIX_DAILY_INBOX_TOP=10
BUGFIX_DAILY_INBOX_OUT=tmp/bugfix-daily-inbox.json
BUGFIX_RETENTION_CRON_ENABLED=false
BUGFIX_RETENTION_CRON_EXPRESSION=30 3 * * *
BUGFIX_RETENTION_MONTHS=6

# ============================================================
# WS10 — Integracja push PS ENVI -> AQM 3.0 (umowy typu „AQM")
# ============================================================
# Baza URL AQM dla pushu (dev: lokalny). Bez końcowego slasha.
AQM_SYNC_BASE_URL=
# Bearer service-token wysyłany do AQM. SEKRET — nie commitować wartości.
# Musi się zgadzać z AQM PS_ENVI_SYNC_TOKEN.
AQM_SYNC_TOKEN=
# Allowlist id typów umów wyzwalających push (CSV). Domyślnie 10 (typ „AQM").
AQM_SYNC_CONTRACT_TYPE_IDS=10
# Interwał drainera outbox w ms (re-wysyłka PENDING/FAILED). Domyślnie 60000; 0 wyłącza.
AQM_SYNC_DRAIN_INTERVAL_MS=60000

# ============================================================
# SYNC-P1 — Integracja sync PS ENVI -> FIDman (umowy typu 3/4)
# ============================================================
# Baza URL FIDman dla sync (bez końcowego slasha).
FIDMAN_SYNC_BASE_URL=
# Bearer service-token wysyłany do FIDman. SEKRET — nie commitować wartości.
FIDMAN_SYNC_TOKEN=
# Allowlist id typów umów wyzwalających sync (CSV). Domyślnie 3,4.
FIDMAN_SYNC_CONTRACT_TYPE_IDS=3,4
# Interwał drainera outbox w ms (re-wysyłka PENDING/FAILED). Domyślnie 60000; 0 wyłącza.
FIDMAN_SYNC_DRAIN_INTERVAL_MS=60000

# ============================================================
# NIP-G1 — Lookup PS ENVI -> GUS BIR (autouzupełnianie formularza encji)
# ============================================================
# Klucz produkcyjny GUS BIR. SEKRET — nie commitować wartości.
# BLOKADA do gate G-N1: brak klucza -> POST /entities/lookup-nip zwraca 503.
GUS_BIR_KEY=
